{
  "manifest_version": 3,
  "name": "GitHub Notification Cleaner",
  "description": "Mark non-open (merged, closed, draft) GitHub notification PRs/issues as Done with one click.",
  "version": "1.1.0",
  "permissions": ["activeTab", "scripting", "tabs"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
